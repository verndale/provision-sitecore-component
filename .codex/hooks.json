        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/scripts/hooks/pretooluse-guard.cjs\" --platform codex"
          }
        ]
      },
      {
        "matcher": "^apply_patch$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/scripts/hooks/pretooluse-guard.cjs\" --platform codex"
          }
        ]
      }
    ]
  }
}
