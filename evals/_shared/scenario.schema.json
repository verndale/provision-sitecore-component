{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verndale.github.io/provision-sitecore-component/evals/_shared/scenario.schema.json",
  "title": "provision-sitecore-component skill eval scenario",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "skills",
    "query",
    "files",
    "expected_behavior",
    "must_not",
    "tags",
    "gap"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)+$",
      "minLength": 5
    },
    "title": {
      "type": "string",
      "minLength": 5
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      }
    },
    "query": {
      "type": "string",
      "minLength": 20
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "expected_behavior": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "minLength": 20
      }
    },
    "must_not": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 10
      }
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "happy-path",
          "datasource",
          "page-driven",
          "push-gate",
          "session-scoped",
          "no-invent-source",
          "boundary",
          "confluence-hard-stop",
          "wrong-adapter",
          "missing-env",
          "retry-gate",
          "manifest-repair",
          "check-only"
        ]
      }
    },
    "gap": {
      "type": "string",
      "minLength": 20
    }
  }
}
